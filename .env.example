# =====================================================
# 壹信 IM 环境变量配置
# =====================================================
# 复制此文件为 .env 并填入实际值

# ------------------- Server -------------------
SERVER_PORT=8080
WS_PORT=8081

# ------------------- Database (PostgreSQL) -------------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=im_db

# ------------------- Redis -------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ------------------- JWT (必需) -------------------
# 生成密钥命令: openssl rand -base64 32
JWT_SECRET=your_very_long_secure_jwt_secret_key_here
JWT_EXPIRE=168

# ------------------- WebSocket -------------------
WS_HEARTBEAT=30
WS_MAX_CONNS=100000

# ------------------- OSS (可选) -------------------
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY=
# OSS_ACCESS_SECRET=
# OSS_BUCKET=
